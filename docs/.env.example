# report-master — 環境變數範本
#
# 用法：複製此檔為 .env，並填入實際值。
#   cp docs/.env.example .env
#
# .env 載入鏈（由低到高覆蓋）：
#   1. system env  (系統全域)
#   2. user env    (~/.config/report-master/.env)
#   3. project env (<project>/.env)
#
# 所有變數皆為 optional，但 font path / report root 建議明確填。

# ─── 字體路徑（必填，建議明確）─────────────────────────────────
# 中文字體（標楷體）。絕對路徑或相對 <project> 的相對路徑。
REPORT_MASTER_CJK_FONT=/usr/share/fonts/truetype/arphic/uming.ttf
REPORT_MASTER_CJK_FONT_NAME=標楷體

# 英文字體（Times New Roman）。絕對路徑或相對路徑。
REPORT_MASTER_LATIN_FONT=/usr/share/fonts/truetype/liberation/LiberationSerif-Regular.ttf
REPORT_MASTER_LATIN_FONT_NAME=Times New Roman

# ─── 報告輸出根目錄（必填，建議明確）────────────────────────────
# 預設報告專案的存放位置；project_manager init 若不指定 --name 則用此路徑。
REPORT_MASTER_ROOT=~/Documents/reports

# ─── 引用設定（optional）────────────────────────────────────────
# CSL 引用樣式檔（相對 <project>）。
REPORT_MASTER_CSL_FILE=APA.csl

# BibTeX 資料庫（相對 <project>）。
REPORT_MASTER_BIB_FILE=references.bib

# ─── LLM API（optional，Stage 2/3 預留）─────────────────────────
# Executor / Strategist 呼叫 LLM 用的 API key。
REPORT_MASTER_LLM_API_KEY=
REPORT_MASTER_LLM_MODEL=claude-sonnet-4-5

# ─── 行為開關（optional）────────────────────────────────────────
# 是否在 Stage 3 嵌入字體到 PDF（建議 true）。
REPORT_MASTER_EMBED_FONTS=true

# 是否啟用 tagged PDF（WCAG / Section 508，預設 false）。
REPORT_MASTER_TAGGED_PDF=false

# 預設語言變體（zh-TW / zh-CN / en-US / en-GB）。
REPORT_MASTER_LANGUAGE_VARIANT=zh-TW

# ─── 除錯（optional）────────────────────────────────────────────
# 設為 1 開啟詳細 log；設為 0 靜默。
REPORT_MASTER_VERBOSE=0
